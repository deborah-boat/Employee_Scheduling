PORT=4000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL="postgresql://user:password@localhost:5432/employee_scheduling"
LOG_LEVEL=info

# Auth0 — Required for authentication
# Create a Regular Web Application at https://auth0.com and copy the values below
AUTH0_SECRET=a-long-random-secret-used-to-encrypt-the-session-cookie
AUTH0_BASE_URL=http://localhost:4000
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_ISSUER_BASE_URL=https://your-tenant.region.auth0.com
AUTH0_POST_LOGOUT_REDIRECT=http://localhost:5173
