generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  role        String
  displayName String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee?
}

model Employee {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  position       String?
  profilePicture String?
  loginCode      String?
  userId         Int?            @unique
  availability   Availability[]
  user           User?           @relation(fields: [userId], references: [id])
  shifts         EmployeeShift[]
}

model Shift {
  id           Int              @id @default(autoincrement())
  name         String
  start_time   String
  end_time     String
  availability Availability[]
  instances    ShiftInstances[]
}

model ShiftInstances {
  id        Int             @id @default(autoincrement())
  shift_id  Int
  date      DateTime
  employees EmployeeShift[]
  shift     Shift           @relation(fields: [shift_id], references: [id])
}

model EmployeeShift {
  id              Int            @id @default(autoincrement())
  employeeId      Int
  shiftInstanceId Int
  employee        Employee       @relation(fields: [employeeId], references: [id])
  shiftInstance   ShiftInstances @relation(fields: [shiftInstanceId], references: [id])
}

model Availability {
  id         Int      @id @default(autoincrement())
  employeeId Int
  date       DateTime
  shift_id   Int
  status     String
  employee   Employee @relation(fields: [employeeId], references: [id])
  shift      Shift    @relation(fields: [shift_id], references: [id])
}
